#!/usr/bin/env node
// lvthn -- platform binary shim
// Finds the correct pre-compiled binary for this OS/arch and runs it.

'use strict';

const { execFileSync } = require('child_process');
const { resolve } = require('path');

const PACKAGES = {
  'linux-x64':   '@xero/lvthn-linux-x64',
  'linux-arm64': '@xero/lvthn-linux-arm64',
  'darwin-x64':  '@xero/lvthn-darwin-x64',
  'darwin-arm64':'@xero/lvthn-darwin-arm64',
  'win32-x64':   '@xero/lvthn-win32-x64',
};

const isWin = process.platform === 'win32';
const binaryName = isWin ? 'lvthn.exe' : 'lvthn';
const key = `${process.platform}-${process.arch}`;
const pkg = PACKAGES[key];

if (!pkg) {
  process.stderr.write(
    `lvthn: unsupported platform ${key}\n` +
    `Supported: ${Object.keys(PACKAGES).join(', ')}\n`
  );
  process.exit(1);
}

let binaryPath;
try {
  binaryPath = resolve(require.resolve(`${pkg}/package.json`), '..', 'bin', binaryName);
} catch {
  process.stderr.write(
    `lvthn: could not find platform package ${pkg}\n` +
    `Try reinstalling: npm i -g lvthn\n`
  );
  process.exit(1);
}

try {
  execFileSync(binaryPath, process.argv.slice(2), { stdio: 'inherit' });
} catch (err) {
  process.exit(err.status ?? 1);
}
